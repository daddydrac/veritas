@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix veritas: <https://github.com/daddydrac/veritas/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

veritas:ResearchObjectiveShape a sh:NodeShape ;
  sh:targetClass veritas:ResearchObjective ;
  sh:property [ sh:path [ sh:inversePath veritas:achievesObjective ] ; sh:minCount 1 ; sh:message "Every ResearchObjective must be achieved by at least one Plan, Task, Process, or Result." ] .

veritas:PlanShape a sh:NodeShape ;
  sh:targetClass veritas:Plan ;
  sh:property [ sh:path veritas:hasTaskSpecification ; sh:minCount 1 ; sh:class veritas:TaskSpecification ; sh:message "Every Plan must contain at least one TaskSpecification." ] ;
  sh:property [ sh:path veritas:validatedBy ; sh:minCount 1 ; sh:class veritas:ValidationCheckSpecification ; sh:message "Every production-bound Plan must have a ValidationCheckSpecification." ] .

veritas:RiskShape a sh:NodeShape ;
  sh:targetClass veritas:Risk ;
  sh:or (
    [ sh:property [ sh:path veritas:mitigatedBy ; sh:minCount 1 ] ]
    [ sh:property [ sh:path veritas:acceptedByDecision ; sh:minCount 1 ] ]
    [ sh:property [ sh:path veritas:hasStatus ; sh:hasValue "blocked" ] ]
  ) ;
  sh:message "Every Risk must be mitigated, explicitly accepted, or blocked." .

veritas:SymbolicShadowShape a sh:NodeShape ;
  sh:targetClass veritas:SymbolicShadow ;
  sh:property [ sh:path veritas:derivedFrom ; sh:minCount 1 ; sh:message "Every SymbolicShadow used by Veritas must be derived from evidence." ] ;
  sh:property [ sh:path veritas:hasExpressionText ; sh:minCount 1 ; sh:datatype xsd:string ; sh:message "Every SymbolicShadow must have expression text." ] ;
  sh:property [ sh:path veritas:hasFormulaSource ; sh:minCount 1 ; sh:message "Every SymbolicShadow must record extraction source." ] .

veritas:InvariantShape a sh:NodeShape ;
  sh:targetClass veritas:Invariant ;
  sh:property [ sh:path veritas:hasTransformationFamily ; sh:minCount 1 ; sh:message "Every Invariant must specify the transformation family under which it is invariant." ] .

veritas:RepresentationMapShape a sh:NodeShape ;
  sh:targetClass veritas:RepresentationMap ;
  sh:property [ sh:path veritas:mapsFromSurface ; sh:minCount 1 ; sh:message "RepresentationMap must map from a SurfacePhenomenonDescription." ] ;
  sh:property [ sh:path veritas:mapsToLatentStructure ; sh:minCount 1 ; sh:message "RepresentationMap must map to a LatentStructureDescription." ] .

veritas:GenerativeNecessityClaimShape a sh:NodeShape ;
  sh:targetClass veritas:GenerativeNecessityClaim ;
  sh:property [ sh:path veritas:supportedByEvidence ; sh:minCount 1 ; sh:message "GenerativeNecessityClaim must be evidence-backed." ] ;
  sh:property [ sh:path veritas:hasProofStatus ; sh:minCount 1 ; sh:message "GenerativeNecessityClaim must have proof status: speculative, plausible, proved, formalized, false, or blocked." ] ;
  sh:property [ sh:path veritas:testedByTransferTest ; sh:minCount 1 ; sh:message "GenerativeNecessityClaim must include a transfer test before discovery status is claimed." ] .

veritas:SourceCodeArtifactShape a sh:NodeShape ;
  sh:targetClass veritas:SourceCodeArtifact ;
  sh:property [ sh:path veritas:validatedBy ; sh:minCount 1 ; sh:message "SourceCodeArtifact must have validation checks." ] ;
  sh:property [ sh:path veritas:testedBy ; sh:minCount 1 ; sh:message "SourceCodeArtifact must be connected to tests." ] .

veritas:BuildArtifactShape a sh:NodeShape ;
  sh:targetClass veritas:BuildArtifact ;
  sh:property [ sh:path veritas:hasStatus ; sh:minCount 1 ; sh:message "BuildArtifact must have explicit status." ] .

veritas:LoopSpecificationShape a sh:NodeShape ;
  sh:targetClass veritas:LoopSpecification ;
  sh:property [ sh:path veritas:hasTerminationCondition ; sh:minCount 1 ; sh:message "LoopSpecification must have a termination condition." ] .

# Production math-to-code extraction obligations added in the hardening pass.
veritas:FormulaImageReviewShape a sh:NodeShape ;
  sh:targetClass veritas:SymbolicShadow ;
  sh:property [ sh:path veritas:hasConfidenceValue ; sh:minCount 1 ; sh:message "SymbolicShadow must include extraction confidence before use in math-to-code." ] ;
  sh:property [ sh:path veritas:hasHumanValidationStatus ; sh:minCount 1 ; sh:message "SymbolicShadow must record whether a human approved, edited, rejected, or auto-approved it." ] .

veritas:MathDiscoveryReadinessShape a sh:NodeShape ;
  sh:targetClass veritas:MathematicalDiscoveryArtifact ;
  sh:or (
    [ sh:property [ sh:path veritas:hasInvariant ; sh:minCount 1 ] ]
    [ sh:property [ sh:path veritas:hasStatus ; sh:hasValue "exploratory" ] ]
    [ sh:property [ sh:path veritas:hasStatus ; sh:hasValue "speculative" ] ]
  ) ;
  sh:message "MathematicalDiscoveryArtifact must either identify invariants or be explicitly marked exploratory/speculative." .

# Pass 4: representation-first mathematical research-to-code obligations.
veritas:Pass4SymbolicShadowMathReadinessShape a sh:NodeShape ;
  sh:targetClass veritas:SymbolicShadow ;
  sh:property [ sh:path veritas:hasHumanValidationStatus ; sh:minCount 1 ; sh:message "SymbolicShadow must record human validation status before math-to-code." ] ;
  sh:property [ sh:path veritas:hasConfidenceValue ; sh:minCount 1 ; sh:message "SymbolicShadow must record extraction confidence before math-to-code." ] .

veritas:Pass4MathematicalDiscoveryArtifactShape a sh:NodeShape ;
  sh:targetClass veritas:MathematicalDiscoveryArtifact ;
  sh:property [ sh:path veritas:hasAxiomMap ; sh:minCount 1 ; sh:message "Representation-first math artifacts must include Axiom Map references." ] ;
  sh:property [ sh:path veritas:hasRepresentationMap ; sh:minCount 1 ; sh:message "Representation-first math artifacts must include a representation map." ] .

# Phase 5: production governance closure. These rules strengthen source/build and
# validation-finding obligations without requiring live SHACL execution in tests.
veritas:ProductionBuildArtifactValidationShape a sh:NodeShape ;
  sh:targetClass veritas:BuildArtifact ;
  sh:property [ sh:path veritas:validatedBy ; sh:minCount 1 ; sh:message "BuildArtifact must link to a VerificationResult or ValidationCheckSpecification before production status is accepted." ] .

veritas:ShaclFindingShape a sh:NodeShape ;
  sh:targetClass veritas:Finding ;
  sh:property [ sh:path veritas:derivedFrom ; sh:minCount 1 ; sh:message "SHACL Finding must derive from a run, validation report, graph, or evidence artifact." ] ;
  sh:property [ sh:path veritas:hasStatus ; sh:minCount 1 ; sh:message "SHACL Finding must have status open, closed, waived, or accepted." ] ;
  sh:property [ sh:path veritas:hasDescription ; sh:minCount 1 ; sh:message "SHACL Finding must include a human-readable message." ] .
