<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:vann="http://purl.org/vocab/vann/"
  xmlns:veritas="https://github.com/daddydrac/veritas/ontology#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <!-- OWL-DL hygiene: declare external annotation properties used in annotations. -->
  <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
  <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
  <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
  <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
  <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
  <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
  <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>

  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasCapabilityToComplexityRatio">
    <rdfs:label xml:lang="en">has capability-to-complexity ratio</rdfs:label>
    <skos:definition xml:lang="en">Relates a plan, design, component, or representation to a capability-to-complexity ratio measurement.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#CapabilityToComplexityRatio"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#CohesionQuality">
    <rdfs:label xml:lang="en">cohesion quality</rdfs:label>
    <skos:definition xml:lang="en">A design quality concerning how well responsibilities, behaviors, and concepts belong together within a component, plan, or representation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DesignQuality"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#OperationalCapability">
    <rdfs:label xml:lang="en">operational capability</rdfs:label>
    <skos:definition xml:lang="en">A capability for deployment, observability, runtime diagnosis, incident response, or operational control.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Capability"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#BackCheckProcess">
    <rdfs:label xml:lang="en">back-check process</rdfs:label>
    <skos:definition xml:lang="en">A conformance check process that revisits earlier reasoning, control flow, assumptions, evidence, risks, and validation obligations to identify malformed logic.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#ConformanceCheckProcess"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#realizesCapability">
    <rdfs:label xml:lang="en">realizes capability</rdfs:label>
    <skos:definition xml:lang="en">Relates a process to a capability realized during that process.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#EngineeringProcess"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#Capability"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ValidationCheckProcess">
    <rdfs:label xml:lang="en">validation check process</rdfs:label>
    <skos:definition xml:lang="en">A planned engineering act that executes a validation check specification and produces evidence or findings.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PlannedEngineeringAct"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#mapsFromSurface">
    <rdfs:label xml:lang="en">maps from surface</rdfs:label>
    <skos:definition xml:lang="en">Relates a representation map to the surface phenomenon description used as its domain-side description.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationMap"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#SurfacePhenomenonDescription"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasPostcondition">
    <rdfs:label xml:lang="en">has postcondition</rdfs:label>
    <skos:definition xml:lang="en">Relates a transition, task, action, process, proof step, or deployment step to a postcondition.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#Postcondition"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Justification">
    <rdfs:label xml:lang="en">justification</rdfs:label>
    <skos:definition xml:lang="en">An evidence artifact explaining why a claim, decision, design, mitigation, or plan step is supported.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EvidenceArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ExecutionEnvironmentSpecification">
    <rdfs:label xml:lang="en">execution environment specification</rdfs:label>
    <skos:definition xml:lang="en">A runtime environment specification emphasizing where and under what conditions a process executes.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RuntimeEnvironmentSpecification"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#checksConformanceTo">
    <rdfs:label xml:lang="en">checks conformance to</rdfs:label>
    <skos:definition xml:lang="en">Relates a conformance check specification or process to the specification it checks.</skos:definition>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Metric">
    <rdfs:label xml:lang="en">metric</rdfs:label>
    <skos:definition xml:lang="en">A measurement artifact representing a measured property of a system, process, service, environment, or user-facing outcome.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasLikelihoodValue">
    <rdfs:label xml:lang="en">has likelihood value</rdfs:label>
    <skos:definition xml:lang="en">Relates a likelihood estimate to a decimal likelihood value.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#LikelihoodEstimate"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasInvariant">
    <rdfs:label xml:lang="en">has invariant</rdfs:label>
    <skos:definition xml:lang="en">Relates a mathematical discovery artifact to an invariant.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#Invariant"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasImpactEstimate">
    <rdfs:label xml:lang="en">has impact estimate</rdfs:label>
    <skos:definition xml:lang="en">Relates a risk to an impact estimate.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#Risk"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#ImpactEstimate"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#buildsInto">
    <rdfs:label xml:lang="en">builds into</rdfs:label>
    <skos:definition xml:lang="en">Relates a source code artifact to a build artifact produced from it.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#SourceCodeArtifact"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#BuildArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#introducesDependency">
    <rdfs:label xml:lang="en">introduces dependency</rdfs:label>
    <skos:definition xml:lang="en">Relates a plan, task, design, or component to a dependency specification it introduces.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#DependencySpecification"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#emitsSignal">
    <rdfs:label xml:lang="en">emits signal</rdfs:label>
    <skos:definition xml:lang="en">Relates a deployment unit, service, process, or runtime environment to an observable signal.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#ObservableSignal"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ConceptualSurfaceAreaQuality">
    <rdfs:label xml:lang="en">conceptual surface-area quality</rdfs:label>
    <skos:definition xml:lang="en">A design quality concerning how many concepts, rules, branches, dependencies, and exceptions a human or agent must track.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#ComplexityQuality"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DataRisk">
    <rdfs:label xml:lang="en">data risk</rdfs:label>
    <skos:definition xml:lang="en">A risk concerning data quality, data loss, privacy, lineage, availability, schema drift, or semantic mismatch.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Risk"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#PlanningHorizon">
    <rdfs:label xml:lang="en">planning horizon</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact specifying the temporal or scope boundary for a plan.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#deployedAs">
    <rdfs:label xml:lang="en">deployed as</rdfs:label>
    <skos:definition xml:lang="en">Relates a software component or build artifact to a deployment unit specification.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#DeploymentUnitSpecification"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#PipelineExecutionProcess">
    <rdfs:label xml:lang="en">pipeline execution process</rdfs:label>
    <skos:definition xml:lang="en">A planned engineering act that executes a pipeline specification.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PlannedEngineeringAct"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Ontology rdf:about="https://github.com/daddydrac/veritas/ontology">
    <owl:versionIRI rdf:resource="https://github.com/daddydrac/veritas/ontology/0.1.0"/>
    <rdfs:label xml:lang="en">Veritas Ontology</rdfs:label>
    <dcterms:title xml:lang="en">Veritas: A BFO/CCO-Aligned Ontology for Research, Engineering Planning, and Correctness</dcterms:title>
    <dcterms:creator xml:lang="en">Generated for Jay Weinberg / Aktiver research-agent architecture</dcterms:creator>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-09</dcterms:created>
    <owl:versionInfo xml:lang="en">0.1.0-draft</owl:versionInfo>
    <vann:preferredNamespacePrefix>veritas</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>https://github.com/daddydrac/veritas/ontology#</vann:preferredNamespaceUri>
    <dcterms:description xml:lang="en">Veritas is an OWL-DL application ontology aligned to BFO and CCO. It models expert mathematical research, software architecture, software engineering, DevOps/SRE operations, risk, evidence, simplicity pressure, and control-flow correctness.</dcterms:description>
    <owl:imports rdf:resource="http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/InformationEntityOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/EventOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/AgentOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/ArtifactOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/QualityOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/ExtendedRelationOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/TimeOntology"/>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/UnitsOfMeasureOntology"/>
    <veritas:owlDlNote xml:lang="en">This draft uses separate IRIs for classes, object properties, datatype properties, and annotation properties; does not use classes as individuals; avoids metamodeling; and keeps closed-world completeness checks outside OWL.</veritas:owlDlNote>
    <veritas:competencyQuestion xml:lang="en">Which plan achieves an objective while minimizing complexity and unmitigated risk?</veritas:competencyQuestion>
    <veritas:competencyQuestion xml:lang="en">Which mathematical claim lacks an explicit transformation family, invariant, evidence, or proof status?</veritas:competencyQuestion>
    <veritas:competencyQuestion xml:lang="en">Which control-flow branches lack preconditions, postconditions, termination conditions, or recovery paths?</veritas:competencyQuestion>
    <veritas:competencyQuestion xml:lang="en">Which runtime deployment unit lacks observable signals, SLOs, alerts, or runbooks?</veritas:competencyQuestion>
    <veritas:competencyQuestion xml:lang="en">Which assumption is unverified and blocks a task, milestone, or engineering objective?</veritas:competencyQuestion>
  </owl:Ontology>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#CounterexampleArtifact">
    <rdfs:label xml:lang="en">counterexample artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact describing an object or case that satisfies stated hypotheses while falsifying a claim or proposed invariant.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#invalidatedBy">
    <rdfs:label xml:lang="en">invalidated by</rdfs:label>
    <skos:definition xml:lang="en">Relates a claim, plan, artifact, process, representation, invariant, or risk to evidence or a finding that invalidates it.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#EvidenceArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#MissingPostconditionFinding">
    <rdfs:label xml:lang="en">missing postcondition finding</rdfs:label>
    <skos:definition xml:lang="en">A malformed control-flow finding that identifies a transition, action, task, or proof step lacking required postconditions.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MalformedControlFlowFinding"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasCompressionPrinciple">
    <rdfs:label xml:lang="en">has compression principle</rdfs:label>
    <skos:definition xml:lang="en">Relates a mathematical discovery artifact to a compression principle.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#CompressionPrinciple"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#blockedBy">
    <rdfs:label xml:lang="en">blocked by</rdfs:label>
    <skos:definition xml:lang="en">Relates a task, plan, objective, process, or claim to something that blocks it.</skos:definition>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasPriority">
    <rdfs:label xml:lang="en">has priority</rdfs:label>
    <skos:definition xml:lang="en">Relates an artifact, task, risk, decision, or finding to a priority label.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#UnnecessaryDependencyFinding">
    <rdfs:label xml:lang="en">unnecessary dependency finding</rdfs:label>
    <skos:definition xml:lang="en">A finding that a dependency adds complexity, risk, coupling, or operational burden without necessary capability gain.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Finding"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasConstraint">
    <rdfs:label xml:lang="en">has constraint</rdfs:label>
    <skos:definition xml:lang="en">Relates a plan, task, artifact, process, design, or representation to a constraint specification.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#ConstraintSpecification"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#UnverifiedAssumptionFinding">
    <rdfs:label xml:lang="en">unverified assumption finding</rdfs:label>
    <skos:definition xml:lang="en">A finding that identifies an assumption lacking sufficient verification evidence.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Finding"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#testedBy">
    <rdfs:label xml:lang="en">tested by</rdfs:label>
    <skos:definition xml:lang="en">Relates a component, artifact, contract, behavior, or process to a test specification.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#TestSpecification"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#LatentVariableDescription">
    <rdfs:label xml:lang="en">latent variable description</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact identifying a latent variable and its evidence, invariance, interpretability, and transfer status.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:AnnotationProperty rdf:about="https://github.com/daddydrac/veritas/ontology#module">
    <rdfs:label xml:lang="en">module</rdfs:label>
    <skos:definition xml:lang="en">Names the ontology module or concern area for a class or property.</skos:definition>
  </owl:AnnotationProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasLatentStructure">
    <rdfs:label xml:lang="en">has latent structure</rdfs:label>
    <skos:definition xml:lang="en">Relates a mathematical discovery artifact to a latent structure description.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#LatentStructureDescription"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#dependsOnTask">
    <rdfs:label xml:lang="en">depends on task</rdfs:label>
    <skos:definition xml:lang="en">Relates a task specification to another task specification required before or during it.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#TaskSpecification"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#TaskSpecification"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasComplexityQuality">
    <rdfs:label xml:lang="en">has complexity quality</rdfs:label>
    <skos:definition xml:lang="en">Relates a plan, artifact, component, representation, process, or design to a complexity quality.</skos:definition>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#ComplexityQuality"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ModuleSpecification">
    <rdfs:label xml:lang="en">module specification</rdfs:label>
    <skos:definition xml:lang="en">A software component specification describing a module-level unit of code organization.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#SoftwareComponent"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://github.com/daddydrac/veritas/ontology#mapsToLatentStructure">
    <rdfs:label xml:lang="en">maps to latent structure</rdfs:label>
    <skos:definition xml:lang="en">Relates a representation map to the latent structure description used as its codomain-side description.</skos:definition>
    <rdfs:domain rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationMap"/>
    <rdfs:range rdf:resource="https://github.com/daddydrac/veritas/ontology#LatentStructureDescription"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasRiskScore">
