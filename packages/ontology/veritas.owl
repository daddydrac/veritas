  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#OperationalBurdenQuality">
    <rdfs:label xml:lang="en">operational burden quality</rdfs:label>
    <skos:definition xml:lang="en">A design quality concerning the ongoing effort required to deploy, observe, maintain, recover, and evolve a system.</skos:definition>
