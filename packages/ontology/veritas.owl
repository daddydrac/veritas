  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RecoveryPath">
    <rdfs:label xml:lang="en">recovery path</rdfs:label>
    <skos:definition xml:lang="en">A control-flow specification describing a valid transition sequence from error, degraded, invalid, or exceptional states toward safe or accepted states.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#ControlFlowSpecification"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#InterpretabilityCertificate">
    <rdfs:label xml:lang="en">interpretability certificate</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact explaining the human-auditable meaning of latent variables, transformations, invariants, or compression.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TestSpecification">
    <rdfs:label xml:lang="en">test specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying an experiment, check, assertion, or validation procedure for software behavior.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#BuildArtifact">
    <rdfs:label xml:lang="en">build artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact produced by a build process, such as an executable, image, wheel, binary, or generated package.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TerminationCondition">
    <rdfs:label xml:lang="en">termination condition</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying a condition under which a loop, recursion, retry, search, or process stops.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DataStoreSpecification">
    <rdfs:label xml:lang="en">data store specification</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact describing a data store, its access patterns, durability, ownership, and operational constraints.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#SoftwareComponent">
    <rdfs:label xml:lang="en">software component</rdfs:label>
    <skos:definition xml:lang="en">An information artifact representing a logical unit of software design or implementation, distinct from a running execution process.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#SymbolicShadow">
    <rdfs:label xml:lang="en">symbolic shadow</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact such as an equation, formula, diagram, theorem statement, or algorithm that records a deeper generative structure.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#PlannedEngineeringAct">
    <rdfs:label xml:lang="en">planned engineering act</rdfs:label>
    <skos:definition xml:lang="en">An engineering process that is prescribed by a prescriptive artifact and performed intentionally by an agent or automated agent system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EngineeringProcess"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#AlertSpecification">
    <rdfs:label xml:lang="en">alert specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying detection logic and notification behavior for operational conditions.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#CompressionFidelityAssessment">
    <rdfs:label xml:lang="en">compression fidelity assessment</rdfs:label>
    <skos:definition xml:lang="en">A measurement or assessment artifact stating whether a compression preserves required invariants, constraints, recursive behavior, and transfer-relevant structure.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact">
    <rdfs:label xml:lang="en">prescriptive artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact that prescribes an entity, process, representation, or engineering behavior.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#LatentStructureDescription">
    <rdfs:label xml:lang="en">latent structure description</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact identifying hidden variables, modes, symmetries, sufficient statistics, attractors, or relational generators visible in a transformed representation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DependencySpecification">
    <rdfs:label xml:lang="en">dependency specification</rdfs:label>
    <skos:definition xml:lang="en">A descriptive or prescriptive artifact specifying that one component, artifact, service, process, or plan depends on another.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ValidationCheckSpecification">
    <rdfs:label xml:lang="en">validation check specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying how to validate, verify, falsify, test, or back-check a claim, plan, artifact, behavior, or process.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DesignQuality">
    <rdfs:label xml:lang="en">design quality</rdfs:label>
    <skos:definition xml:lang="en">A quality inhering in a design, plan, artifact, component, process, or specification and relevant to engineering judgment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <veritas:module xml:lang="en">simplicity</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#SourceCodeArtifact">
    <rdfs:label xml:lang="en">source code artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact containing source code or source-code-level representation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RuntimeEnvironmentSpecification">
    <rdfs:label xml:lang="en">runtime environment specification</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact describing runtime conditions, platform constraints, hardware resources, environment variables, permissions, and dependencies.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ConstraintGeometryDescription">
    <rdfs:label xml:lang="en">constraint geometry description</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact explaining how constraints limit transformations and produce symbolic shadows such as equations or laws.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Runbook">
    <rdfs:label xml:lang="en">runbook</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying operational procedures, incident response steps, rollback steps, or recovery processes.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#InterfaceSpecification">
    <rdfs:label xml:lang="en">interface specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying the surface by which a component, service, module, or process may be used.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ImpactEstimate">
    <rdfs:label xml:lang="en">impact estimate</rdfs:label>
    <skos:definition xml:lang="en">An estimate artifact measuring or ranking the severity of a risk if realized.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EstimateArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#SoftwareSystemSpecification">
    <rdfs:label xml:lang="en">software system specification</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact describing a software system, its boundaries, responsibilities, components, interfaces, and behaviors.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Risk">
    <rdfs:label xml:lang="en">risk</rdfs:label>
    <skos:definition xml:lang="en">A descriptive planning artifact representing a possible failure, loss, delay, invalidity, degradation, or adverse outcome that threatens an objective, process, artifact, assumption, or quality.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact">
    <rdfs:label xml:lang="en">mathematical discovery artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact used to represent mathematical discovery as transformation, constraint, invariant, compression, recursion, necessity, proof, or transfer.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#EstimateArtifact">
    <rdfs:label xml:lang="en">estimate artifact</rdfs:label>
    <skos:definition xml:lang="en">A measurement artifact based on partial evidence or comparison with sufficiently similar cases.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001176"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#StateSpecification">
    <rdfs:label xml:lang="en">state specification</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact specifying a named or described state in a control-flow, plan-flow, runtime-flow, or reasoning-flow model.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ConformanceCheckSpecification">
    <rdfs:label xml:lang="en">conformance check specification</rdfs:label>
    <skos:definition xml:lang="en">A validation check specification that prescribes checking whether an execution, plan, or implementation conforms to a specification.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#VerificationResult">
    <rdfs:label xml:lang="en">verification result</rdfs:label>
    <skos:definition xml:lang="en">A finding produced by a validation or verification process.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Finding"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#SourceDocument">
    <rdfs:label xml:lang="en">source document</rdfs:label>
    <skos:definition xml:lang="en">An evidence artifact that serves as a source for extracted claims, observations, requirements, examples, or citations.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EvidenceArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RepresentationHypothesis">
    <rdfs:label xml:lang="en">representation hypothesis</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact proposing that a change of perspective, coordinate system, embedding, quotient, normal form, or latent representation may reveal simpler structure.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RepresentationMap">
    <rdfs:label xml:lang="en">representation map</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact specifying a map from a surface description to a latent or transformed representation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#AcceptanceCriterion">
    <rdfs:label xml:lang="en">acceptance criterion</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying the condition under which a task, plan, change, or result is accepted.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DeploymentUnitSpecification">
    <rdfs:label xml:lang="en">deployment unit specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive or representational artifact specifying a deployable unit, packaging boundary, image, service release, or runtime component.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#GenerativeNecessityClaim">
    <rdfs:label xml:lang="en">generative necessity claim</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact claiming that a structure, equation, algorithm, or theorem is forced by primitives, transformations, constraints, invariants, compression, and recursion.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Assumption">
    <rdfs:label xml:lang="en">assumption</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact accepted provisionally for planning, reasoning, or execution until verified, rejected, or revised.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Finding">
    <rdfs:label xml:lang="en">finding</rdfs:label>
    <skos:definition xml:lang="en">A descriptive evidence artifact reporting a validation result, gap, contradiction, issue, risk, or inferred condition.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EvidenceArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#InformationArtifact">
    <rdfs:label xml:lang="en">information artifact</rdfs:label>
    <skos:definition xml:lang="en">An application-level information content entity used by research, planning, engineering, operations, or validation work.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000958"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TransformationFamily">
    <rdfs:label xml:lang="en">transformation family</rdfs:label>
    <skos:definition xml:lang="en">A representational artifact describing a class of admissible, forbidden, identity-preserving, or identity-destroying transformations.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ObservableSignal">
    <rdfs:label xml:lang="en">observable signal</rdfs:label>
    <skos:definition xml:lang="en">A descriptive or measurement artifact emitted, recorded, or derived from runtime behavior for observability.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Invariant">
    <rdfs:label xml:lang="en">invariant</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact stating what remains preserved under a specified transformation family.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RepresentationalArtifact">
    <rdfs:label xml:lang="en">representational artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact that represents some entity, process, structure, pattern, or possible execution path.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001069"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#EngineeringProcess">
    <rdfs:label xml:lang="en">engineering process</rdfs:label>
    <skos:definition xml:lang="en">A process in which engineering, research, implementation, validation, deployment, or operation occurs.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#MitigationSpecification">
    <rdfs:label xml:lang="en">mitigation specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying actions, design changes, checks, constraints, or contingencies intended to reduce a risk.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact">
    <rdfs:label xml:lang="en">descriptive artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact that describes an entity, process, quality, observation, finding, or state of affairs.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000853"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Objective">
    <rdfs:label xml:lang="en">objective</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact that specifies a desired end state or desired result.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Plan">
    <rdfs:label xml:lang="en">plan</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact that organizes tasks, decisions, assumptions, constraints, and validation checks to achieve an objective.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#EvidenceArtifact">
    <rdfs:label xml:lang="en">evidence artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact used to support, weaken, verify, invalidate, or contextualize a claim, risk, decision, assumption, plan, proof, or finding.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RiskAssessment">
    <rdfs:label xml:lang="en">risk assessment</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact evaluating likelihood, impact, evidence, mitigation status, affected objective, and acceptance state for a risk.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TransformationSpecification">
    <rdfs:label xml:lang="en">transformation specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive or representational artifact specifying a transformation, its domain, codomain, admissibility conditions, and preservation behavior.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ImplementationProcess">
    <rdfs:label xml:lang="en">implementation process</rdfs:label>
    <skos:definition xml:lang="en">A planned engineering act that creates or changes source code, configuration, tests, or build artifacts.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PlannedEngineeringAct"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Capability">
    <rdfs:label xml:lang="en">capability</rdfs:label>
    <skos:definition xml:lang="en">A realizable entity borne by an agent, artifact, system, or component and realized in an appropriate process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ContractSpecification">
    <rdfs:label xml:lang="en">contract specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying behavioral obligations, preconditions, postconditions, invariants, or compatibility rules.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">software-engineering</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#LikelihoodEstimate">
    <rdfs:label xml:lang="en">likelihood estimate</rdfs:label>
    <skos:definition xml:lang="en">An estimate artifact measuring or ranking the likelihood of a risk or possible process.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EstimateArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#CompressionPrinciple">
    <rdfs:label xml:lang="en">compression principle</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact explaining what complexity is reduced and what transformation-relevant structure is preserved.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#CapabilityToComplexityRatio">
    <rdfs:label xml:lang="en">capability-to-complexity ratio</rdfs:label>
    <skos:definition xml:lang="en">A measurement artifact comparing delivered capability against introduced complexity.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ServiceLevelObjective">
    <rdfs:label xml:lang="en">service-level objective</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive or measurement artifact specifying target reliability, availability, latency, durability, or user-facing quality.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ControlFlowSpecification">
    <rdfs:label xml:lang="en">control-flow specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact representing allowed states, transitions, branches, loops, guards, invariants, termination conditions, and recovery paths.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ComplexityQuality">
    <rdfs:label xml:lang="en">complexity quality</rdfs:label>
    <skos:definition xml:lang="en">A design quality concerning conceptual surface area, coupling, branching, operational burden, or cognitive burden.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DesignQuality"/>
    <veritas:module xml:lang="en">simplicity-design-quality</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact">
    <rdfs:label xml:lang="en">measurement artifact</rdfs:label>
    <skos:definition xml:lang="en">An information artifact that measures or estimates some quality, risk, cost, confidence, or priority.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001163"/>
    <veritas:module xml:lang="en">core</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#EngineeringPlan">
    <rdfs:label xml:lang="en">engineering plan</rdfs:label>
    <skos:definition xml:lang="en">A plan for building, changing, validating, deploying, or operating an engineered system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Plan"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ConformanceCheckProcess">
    <rdfs:label xml:lang="en">conformance check process</rdfs:label>
    <skos:definition xml:lang="en">A validation process that checks conformance to a control-flow, contract, plan, or behavior specification.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PlannedEngineeringAct"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ConfidenceMeasurement">
    <rdfs:label xml:lang="en">confidence measurement</rdfs:label>
    <skos:definition xml:lang="en">A measurement artifact representing confidence in a claim, finding, estimate, classification, retrieval result, or validation outcome.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#InvariantCondition">
    <rdfs:label xml:lang="en">invariant condition</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying a condition that must remain true across specified transitions or processes.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TradeoffAssessment">
    <rdfs:label xml:lang="en">tradeoff assessment</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact comparing competing qualities, objectives, risks, costs, or design options.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Postcondition">
    <rdfs:label xml:lang="en">postcondition</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying what must hold after a transition, action, task, proof step, deployment, or process completes.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#GuardCondition">
    <rdfs:label xml:lang="en">guard condition</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying when a transition, branch, loop, task, or action is permitted.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#DetectionMechanism">
    <rdfs:label xml:lang="en">detection mechanism</rdfs:label>
    <skos:definition xml:lang="en">A specification, artifact, process, signal, or validation check used to detect a risk, failure mode, or invalid condition.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#InformationArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#EngineeringDecision">
    <rdfs:label xml:lang="en">engineering decision</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact recording a selected option, rejected alternatives, motivations, constraints, and consequences.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TransitionSpecification">
    <rdfs:label xml:lang="en">transition specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying a permitted or forbidden transition between states, including guards, preconditions, postconditions, and effects.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#TaskSpecification">
    <rdfs:label xml:lang="en">task specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying a task to be performed as part of a plan.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#SurfacePhenomenonDescription">
    <rdfs:label xml:lang="en">surface phenomenon description</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact representing observed mathematical or computational behavior before treating the observed representation as fundamental.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#Precondition">
    <rdfs:label xml:lang="en">precondition</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive artifact specifying what must hold before a transition, action, task, proof step, deployment, or process is valid.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RecursiveClosureBehavior">
    <rdfs:label xml:lang="en">recursive closure behavior</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact describing behavior under repeated transformation, composition, iteration, self-application, closure, fixed points, or obstruction.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MathematicalDiscoveryArtifact"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#RiskAcceptanceDecision">
    <rdfs:label xml:lang="en">risk acceptance decision</rdfs:label>
    <skos:definition xml:lang="en">An engineering decision explicitly accepting a risk under stated assumptions, constraints, owner, and review conditions.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#EngineeringDecision"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#MalformedControlFlowFinding">
    <rdfs:label xml:lang="en">malformed control-flow finding</rdfs:label>
    <skos:definition xml:lang="en">A finding that identifies malformed, incomplete, unsafe, or contradictory control-flow structure.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#Finding"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#ConstraintSpecification">
    <rdfs:label xml:lang="en">constraint specification</rdfs:label>
    <skos:definition xml:lang="en">A prescriptive or descriptive artifact specifying a limit on a design, process, plan, representation, or transformation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#PrescriptiveArtifact"/>
    <veritas:module xml:lang="en">planning</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#FailureMode">
    <rdfs:label xml:lang="en">failure mode</rdfs:label>
    <skos:definition xml:lang="en">A descriptive artifact specifying a possible way a system, plan, process, proof, representation, or control flow can fail.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#DescriptiveArtifact"/>
    <veritas:module xml:lang="en">risk</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#LoopSpecification">
    <rdfs:label xml:lang="en">loop specification</rdfs:label>
    <skos:definition xml:lang="en">A control-flow specification describing repeated execution, recurrence, retry, recursion, iteration, or self-application.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#ControlFlowSpecification"/>
    <veritas:module xml:lang="en">control-flow-correctness</veritas:module>
  </owl:Class>
  <owl:Class rdf:about="https://github.com/daddydrac/veritas/ontology#OperationalBurdenMeasurement">
    <rdfs:label xml:lang="en">operational burden measurement</rdfs:label>
    <skos:definition xml:lang="en">A measurement artifact estimating human, automation, cognitive, deployment, maintenance, or incident-response cost.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://github.com/daddydrac/veritas/ontology#MeasurementArtifact"/>
    <veritas:module xml:lang="en">devops-sre</veritas:module>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasText">
    <rdfs:label xml:lang="en">has text</rdfs:label>
    <skos:definition xml:lang="en">Relates an evidence artifact, chunk, or source artifact to extracted text.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasOrdinal">
    <rdfs:label xml:lang="en">has ordinal</rdfs:label>
    <skos:definition xml:lang="en">Relates an ordered artifact such as a chunk to its integer sequence number.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasContentHash">
    <rdfs:label xml:lang="en">has content hash</rdfs:label>
    <skos:definition xml:lang="en">Relates a source artifact to a content hash used for reproducibility and deduplication.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasSourceUrl">
    <rdfs:label xml:lang="en">has source URL</rdfs:label>
    <skos:definition xml:lang="en">Relates a source artifact to the URL from which it was retrieved.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasRawExpressionText">
    <rdfs:label xml:lang="en">has raw expression text</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to the raw expression text extracted from a source document.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasFormulaSource">
    <rdfs:label xml:lang="en">has formula source</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to the extraction source or subsystem that produced it.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasFormulaPattern">
    <rdfs:label xml:lang="en">has formula pattern</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to the extraction pattern that detected it.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasEmbeddingModel">
    <rdfs:label xml:lang="en">has embedding model</rdfs:label>
    <skos:definition xml:lang="en">Relates an indexed evidence artifact to the embedding model used to generate its vector representation.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">retrieval-memory</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasEmbeddingNorm">
    <rdfs:label xml:lang="en">has embedding norm</rdfs:label>
    <skos:definition xml:lang="en">Relates an indexed evidence artifact to the L2 norm of its embedding vector after normalization.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <veritas:module xml:lang="en">retrieval-memory</veritas:module>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasFormulaImagePath">
    <rdfs:label xml:lang="en">has formula image path</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to a local or object-store path of the rendered formula image extracted from a source document.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasFormulaImageStatus">
    <rdfs:label xml:lang="en">has formula image status</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to the status of formula image extraction, such as rendered, missing bbox, or failed.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasHumanValidationStatus">
    <rdfs:label xml:lang="en">has human validation status</rdfs:label>
    <skos:definition xml:lang="en">Relates an extracted evidence, formula, plan, or generated artifact to a human validation status label.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">evidence-validation</veritas:module>
  </owl:DatatypeProperty>

  <!-- Pass 4 mathematical research workflow datatype properties. -->
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasNormalizedExpressionText">
    <rdfs:label xml:lang="en">has normalized expression text</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to normalized LaTeX or normalized symbolic expression text used for exact and semantic retrieval.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasLatexOcrStatus">
    <rdfs:label xml:lang="en">has LaTeX OCR status</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to the status of formula-image-to-LaTeX recognition.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasLatexOcrEngine">
    <rdfs:label xml:lang="en">has LaTeX OCR engine</rdfs:label>
    <skos:definition xml:lang="en">Relates a symbolic shadow to the OCR engine or provider used to derive LaTeX from a formula image.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasAxiomMap">
    <rdfs:label xml:lang="en">has axiom map</rdfs:label>
    <skos:definition xml:lang="en">Relates a mathematical reasoning artifact to the A0-A15 representation-first axioms used in the analysis.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://github.com/daddydrac/veritas/ontology#hasProofStatus">
    <rdfs:label xml:lang="en">has proof status</rdfs:label>
    <skos:definition xml:lang="en">Relates a mathematical claim to proof status such as speculative, plausible, experimentally supported, proved, formalized, false, or blocked.</skos:definition>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <veritas:module xml:lang="en">mathematical-research</veritas:module>
  </owl:DatatypeProperty>

</rdf:RDF>