{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VeritasEvidenceEligibilityRegistry",
  "type": "object",
  "required": ["kind", "version", "planning", "summary", "citations", "formulas"],
  "properties": {
    "kind": {"const": "VeritasEvidenceEligibilityRegistry"},
    "version": {"type": "string"},
    "planning": {
      "type": "object",
      "required": ["allowed", "status", "blocking_reasons", "usable_citation_ids", "eligible_formula_ids"],
      "properties": {
        "allowed": {"type": "boolean"},
        "status": {"type": "string"},
        "blocking_reasons": {"type": "array", "items": {"type": "string"}},
        "usable_citation_ids": {"type": "array", "items": {"type": "string"}},
        "eligible_formula_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "summary": {"type": "object"},
    "citations": {"type": "array"},
    "formulas": {"type": "array"}
  },
  "additionalProperties": true
}
