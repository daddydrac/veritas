{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VeritasHumanCheckpoint",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "question",
    "artifact",
    "options",
    "decision"
  ],
  "properties": {
    "kind": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": [
        "citation_review",
        "formula_review",
        "representation_review",
        "plan_review",
        "code_architecture_review",
        "validation_review",
        "math_to_code_representation_review",
        "math_review"
      ]
    },
    "label": {
      "type": "string"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": "object"
    },
    "artifact_digest": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "pending",
        "approve",
        "edit",
        "reject",
        "skip",
        "auto_approve",
        "waive",
        "ask_for_explanation"
      ]
    },
    "notes": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "policy": {
      "type": "string",
      "enum": [
        "auto_approve",
        "require_all",
        "require_high_risk_only"
      ]
    },
    "required": {
      "type": "boolean"
    },
    "approved": {
      "type": "boolean"
    },
    "blocked": {
      "type": "boolean"
    },
    "waived": {
      "type": "boolean"
    },
    "timestamp_ms": {
      "type": "integer"
    }
  }
}