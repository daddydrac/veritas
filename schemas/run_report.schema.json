{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VeritasRunReport",
  "type": "object",
  "additionalProperties": true,
  "required": ["run_id", "original_task", "files_changed", "commands_run", "final_status"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "original_task": {"type": "string", "minLength": 1},
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array"},
    "final_status": {"type": "string", "enum": ["production_candidate_validated", "validation_failed", "generated_unvalidated", "failed", "cancelled", "awaiting_human_checkpoint"]},
    "model_routes_used": {"type": "object"},
    "provider_route_history": {"type": "array"},
    "validation_results": {"type": "array"},
    "retry_history": {"type": "array"}
  }
}
