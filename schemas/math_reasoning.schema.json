    "symbolic_shadows": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": true}},
    "transfer_tests": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": true}},
    "risks": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
